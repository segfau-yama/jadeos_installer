{
  "name": "jade-installer",
  "private": true,
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.1.12"
  },
  "scripts": {
    "tailwind:build": "npx @tailwindcss/cli -i ./tailwind.css -o ./assets/tailwind.css --minify",
    "tailwind:watch": "npx @tailwindcss/cli -i ./tailwind.css -o ./assets/tailwind.css --watch"
  }
}
